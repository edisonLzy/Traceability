{
  "name": "@traceability/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run src/__tests__/integration",
    "dev": "tsx watch src/index.ts",
    "dev:dispatcher": "tsx watch src/dispatcher.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "start": "node dist/index.js",
    "start:dispatcher": "node dist/dispatcher.js",
    "start:worker": "node dist/worker.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "bullmq": "^5.81.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.0.0",
    "vitest": "catalog:"
  }
}
