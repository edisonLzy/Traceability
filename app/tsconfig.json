{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/*"],
      "@shared/*": ["src/shared/*"],
      "@built-in/*": ["src/built-in/*"]
    }
  },
  "include": ["src", "electron.vite.config.ts"],
  "exclude": [
    "src/main/**",
    "src/preload/**",
    "src/built-in/extension-core/main/**",
    "src/built-in/*/main.ts",
    "src/built-in/main-extensions.ts"
  ]
}
