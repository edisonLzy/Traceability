{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"]
  },
  "include": ["src", "electron.vite.config.ts"],
  "exclude": [
    "src/main/**",
    "src/preload/**",
    "src/built-in/extension-core/main/**",
    "src/built-in/*/main.ts",
    "src/built-in/main-extensions.ts"
  ]
}
